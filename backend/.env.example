# Configuración de Django
SECRET_KEY=tu_secret_key_aqui
DEBUG=False
ALLOWED_HOSTS=tu_dominio.com,localhost,127.0.0.1

# Supabase
SUPABASE_URL=tu_url_de_supabase
SUPABASE_SECRET_KEY=tu_service_role_key
# Opcional: solo si firmas tokens con HS256 (claves legacy). Con claves de firma
# asimétricas (default en proyectos nuevos) déjalo vacío y se usa JWKS.
SUPABASE_JWT_SECRET=

# Hugging Face (Indispensable para AWS Micro)
HF_API_TOKEN=tu_token_de_hugging_face_aqui

# Base de datos (MongoDB para historial)
MONGO_URI=tu_uri_de_mongodb

# Firebase (Para Notificaciones Push)
# Asegúrate de tener un archivo 'firebase-key.json' en esta misma carpeta
# con el formato de llave de servicio de Firebase.

# Detector de código generado por IA (Vía B: perplejidad)
# Modelo causal de código usado para medir perplejidad (se descarga de HF la 1ra vez).
CODE_DETECTOR_MODEL=Qwen/Qwen2.5-Coder-0.5B
# Umbrales de perplejidad (calibrar con tus propios datos por lenguaje):
#   <= LOW  -> muy probable IA ; >= HIGH -> muy probable humano
CODE_DETECTOR_PPL_LOW=1.8
CODE_DETECTOR_PPL_HIGH=4.0
# Mínimo de caracteres para emitir un veredicto (menos = "fragmento insuficiente")
CODE_DETECTOR_MIN_CHARS=80
# Máximo de tokens a evaluar por inferencia
CODE_DETECTOR_MAX_TOKENS=1024
